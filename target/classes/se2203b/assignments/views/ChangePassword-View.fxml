<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="420.0" prefWidth="520.0"
            style="-fx-background-image: url('file:src/main/resources/se2203b/assignments/images/WesternBackground.png'); -fx-background-size: stretch;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="se2203b.assignments.controller.ChangePasswordController">
    <center>
        <VBox alignment="CENTER" spacing="16.0" maxWidth="420.0" BorderPane.alignment="CENTER">
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>

            <Label text="Change Password" style="-fx-font-size:22px; -fx-font-weight:bold;"/>
            <Label text="You must change your password before continuing." textFill="#b00020" wrapText="true"/>

            <Label fx:id="lblSignedInAs" text="Signed in as: [User] ([ROLE])" style="-fx-font-size: 14px; -fx-text-fill: #555555;" />

            <Separator/>

            <GridPane hgap="10.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="150.0"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Current password" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <PasswordField fx:id="txtCurrent" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="New password" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <PasswordField fx:id="txtNew" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Confirm new password" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <PasswordField fx:id="txtConfirm" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label fx:id="lblError" text="" textFill="#b00020" wrapText="true"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <rowConstraints>
                    <RowConstraints/><RowConstraints/><RowConstraints/><RowConstraints/>
                </rowConstraints>
            </GridPane>

            <HBox spacing="10.0">
                <Button text="Change Password" defaultButton="true"
                        onAction="#handleChangePassword" prefWidth="160.0"/>
                <Button text="Exit" cancelButton="true" onAction="#handleExit"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>