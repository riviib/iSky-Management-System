<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="630.0" prefWidth="900.0"
            style="-fx-background-image: url('file:src/main/resources/se2203b/assignments/images/WesternBackground.png');
            -fx-background-size: stretch;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="se2203b.assignments.controller.InitializeISkyController">

    <!-- Centered “card” -->
    <center>
        <VBox fx:id="root" alignment="TOP_CENTER" spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>

            <!-- Header -->
            <VBox maxWidth="720.0" spacing="6.0">
                <Label fx:id="lblTitle" style="-fx-font-size: 22px; -fx-font-weight: bold;" text="First-time setup" />
                <Label fx:id="lblSubtitle" text="This system is not initialized. Create the Master account to continue." textFill="#f80303" wrapText="true" />
                <Label fx:id="lblOneTimeNote" style="-fx-opacity: 0.85;" text="Note: This setup screen will be disabled after initialization." wrapText="true" />
            </VBox>

            <Separator maxWidth="720.0" />

            <!-- Main content: left = form, right = password rules -->
            <GridPane fx:id="grid" hgap="18.0" maxWidth="720.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="420.0" prefWidth="480.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="240.0" prefWidth="240.0" />
                </columnConstraints>

                <!-- Left: Master account form -->
                <VBox fx:id="boxForm" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label fx:id="lblSectionMaster" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Master account" />

                    <GridPane fx:id="gridForm" hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="150.0" prefWidth="160.0" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <!-- Master username -->
                        <Label fx:id="lblMasterUser" text="Master username" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtMasterUser" promptText="e.g., isky-master" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label fx:id="lblMasterUserHelp" style="-fx-opacity: 0.85;" text="Use a unique ID (no default credentials)." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <!-- Optional email -->
                        <Label fx:id="lblMasterEmail" text="Contact email (optional)" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="txtMasterEmail" promptText="e.g., name@isky.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label fx:id="lblMasteremailHelp" style="-fx-opacity: 0.85;" text="Used for notifications in later tasks." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <!-- Password (hidden + shown fields stacked) -->
                        <Label fx:id="lblPwd1" text="New password" GridPane.columnIndex="0" GridPane.rowIndex="4" />

                        <GridPane fx:id="gridPwd1" hgap="8.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="110.0" />
                            </columnConstraints>

                            <!-- Stack two fields in same cell; controller toggles visibility/managed -->
                            <PasswordField fx:id="pwd1" promptText="Enter a strong password" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="txtPwd1Visible" managed="false" promptText="Enter a strong password" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                            <CheckBox fx:id="chkShowPwd1" mnemonicParsing="false" text="Show" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                     <rowConstraints>
                        <RowConstraints />
                     </rowConstraints>
                        </GridPane>

                        <!-- Confirm password -->
                        <Label fx:id="lblPwd2" text="Confirm password" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                        <GridPane fx:id="gridPwd2" hgap="8.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="110.0" />
                            </columnConstraints>

                            <PasswordField fx:id="pwd2" promptText="Re-enter password" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="txtPwd2Visible" managed="false" promptText="Re-enter password" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                            <CheckBox fx:id="chkShowPwd2" mnemonicParsing="false" text="Show" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                     <rowConstraints>
                        <RowConstraints />
                     </rowConstraints>
                        </GridPane>

                        <!-- Status / error line -->
                        <Label fx:id="lblStatus" style="-fx-text-fill: #b00020;" text="" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </VBox>

                <!-- Right: password rules -->
                <VBox fx:id="boxRules" spacing="8.0" style=" -fx-border-color: rgba(0,0,0,0.4); -fx-background-color: rgba(249,255,2,0.11); -fx-background-radius: 8px;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label fx:id="lblRulesTitle" style="-fx-font-size: 13px; -fx-font-weight: bold;" text="Password rules">
                  <padding>
                     <Insets left="5.0" />
                  </padding></Label>

                    <Label fx:id="lblRuleLen" text="• At least 12 characters" wrapText="true">
                  <padding>
                     <Insets left="10.0" right="10.0" />
                  </padding></Label>
                    <Label fx:id="lblRuleCommon" text="• Not a common/weak password" wrapText="true">
                  <padding>
                     <Insets left="10.0" />
                  </padding></Label>
                    <Label fx:id="lblRuleUser" text="• Not the same as the username" wrapText="true">
                  <padding>
                     <Insets left="10.0" />
                  </padding></Label>
                    <Label fx:id="lblRuleChars" text="• Spaces and special characters allowed" wrapText="true">
                  <padding>
                     <Insets left="10.0" />
                  </padding></Label>

                    <Separator />

                    <Label fx:id="lblRuleTip" style="-fx-opacity: 0.9;" text="Tip: Use a passphrase (e.g., 4+ random words)." wrapText="true">
                  <padding>
                     <Insets left="10.0" right="10.0" />
                  </padding></Label>
                </VBox>
            <rowConstraints>
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <!-- Buttons -->
            <HBox fx:id="boxButtons" alignment="CENTER_LEFT" maxWidth="720.0" spacing="10.0">
                <Button fx:id="btnCreateMaster" defaultButton="true" disable="true" onAction="#handleCreateMaster" text="Create Master Account" />
                <Button fx:id="btnExit" cancelButton="true" onAction="#handleExit" text="Exit" />


            </HBox>

        </VBox>
    </center>
</BorderPane>
